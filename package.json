{
  "name": "foolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <25.0.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "prisma db push && node --watch server/index.js",
    "build": "prisma generate && vite build",
    "preview": "vite preview",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "start": "prisma db push && node server/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@studio-freight/lenis": "^1.0.42",
    "animejs": "^3.2.2",
    "concurrently": "^9.1.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "serve": "^14.2.6",
    "split-type": "^0.3.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/cli-service": "^5.0.9",
    "cross-env": "^10.1.0",
    "prisma": "^6.7.0",
    "sass": "^1.99.0",
    "vite": "^8.0.4"
  }
}
