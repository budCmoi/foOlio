rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isOwner(userIdField) {
      return isSignedIn() && request.auth.uid == userIdField;
    }

    function isValidProjectPayload(projectId) {
      return request.resource.data.keys().hasOnly([
          'accent',
          'createdAt',
          'description',
          'id',
          'images',
          'isCustom',
          'link',
          'results',
          'role',
          'statement',
          'tech',
          'title',
          'year'
        ])
        && request.resource.data.keys().hasAll([
          'accent',
          'createdAt',
          'description',
          'id',
          'images',
          'isCustom',
          'link',
          'results',
          'role',
          'statement',
          'tech',
          'title',
          'year'
        ])
        && request.resource.data.id == projectId
        && request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.id.size() <= 120
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 140
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 4000
        && request.resource.data.statement is string
        && request.resource.data.statement.size() > 0
        && request.resource.data.statement.size() <= 1200
        && request.resource.data.role is string
        && request.resource.data.role.size() > 0
        && request.resource.data.role.size() <= 140
        && request.resource.data.link is string
        && request.resource.data.link.size() <= 500
        && request.resource.data.year is string
        && request.resource.data.year.size() > 0
        && request.resource.data.year.size() <= 12
        && request.resource.data.accent is string
        && request.resource.data.accent.size() > 0
        && request.resource.data.accent.size() <= 16
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() > 0
        && request.resource.data.createdAt.size() <= 64
        && request.resource.data.images is list
        && request.resource.data.images.size() > 0
        && request.resource.data.images.size() <= 24
        && request.resource.data.tech is list
        && request.resource.data.tech.size() <= 20
        && request.resource.data.results is list
        && request.resource.data.results.size() <= 20
        && request.resource.data.isCustom == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /transactions/{docId} {
      allow read, update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    match /invoices/{docId} {
      allow read, update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    match /clients/{docId} {
      allow read, update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    match /activityLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isValidProjectPayload(projectId);
      allow delete: if resource.data.isCustom == true;
    }
  }
}